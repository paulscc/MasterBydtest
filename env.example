# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AWS RDS Configuration
AWS_RDS_HOST=your_aws_rds_host
AWS_RDS_PORT=5432
AWS_RDS_DATABASE=your_aws_rds_database_name
AWS_RDS_USER=your_aws_rds_username
AWS_RDS_PASSWORD=your_aws_rds_password

# AWS Credentials (for programmatic access)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Database URL (fallback for client connections)
DATABASE_URL=postgresql://username:password@host:port/database

# Application Configuration
NODE_ENV=development
BUILD_DATE=2024-01-01

# Optional: Custom schema script location
SCHEMA_SCRIPT_PATH=./script_corrected++.sql
